# FastAPI Configuration
DEBUG=True
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# LLM Configuration (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Speech Services (Sarvam AI)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_STT_MODEL=sarvam-2-en
SARVAM_TTS_MODEL=sarvam-tts-en

# Voice Configuration (Pipecat)
PIPECAT_WORKSPACE_ID=your_pipecat_workspace_id
PIPECAT_API_KEY=your_pipecat_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# MCP Configuration
MCP_CRM_URL=http://localhost:8001
MCP_CALENDAR_URL=http://localhost:8002
MCP_GMAIL_URL=http://localhost:8003

# Database Configuration
DATABASE_URL=sqlite:///./realtydb.db
SQLALCHEMY_ECHO=False

# FAISS Configuration
FAISS_INDEX_PATH=./data/property_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# Call Configuration
MAX_CALL_DURATION=3600
CALL_TIMEOUT=600

# Logging
LOG_FILE_PATH=./logs/app.log

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Feature Flags
ENABLE_VOICE_CALLS=True
ENABLE_CHAT_INTERFACE=True
ENABLE_EMAIL_FOLLOWUP=True
ENABLE_CALL_RECORDING=False
